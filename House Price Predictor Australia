#---------------------------------------------    

data = pd.read_csv("melb_data.csv")


region_map = {
        "Eastern Metropolitan": 1,
        "Eastern Victoria": 2,
        "Northern Metropolitan": 3,
        "Northern Victoria": 4,
        "South-Eastern Metropolitan": 5,
        "Southern Metropolitan": 6,
        "Western Metropolitan": 7,
        "Western Victoria": 8}




data['Regionname'] = data['Regionname'].map(region_map)


data = data[['Rooms','Bathroom','YearBuilt',
             'Distance','Landsize',
             'Regionname','Price']]

data = data.dropna()

x = data[['Rooms','Bathroom','YearBuilt',
          'Distance','Landsize','Regionname']]

y = data['Price']

x_train, x_test, y_train, y_test = train_test_split(
    x, y,
    test_size=0.2,
    random_state=0
)

model = LinearRegression()
model.fit(x_train, y_train)

