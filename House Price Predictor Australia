def submit():

    Rooms= askinteger("input","Rooms")
    Bathroom = askinteger("input","Bathroom")
    YearBuilt = askfloat("input","YearBuilt")
    Distance = askfloat("input","Distance")
    Landsize = askfloat("input","Landsize")

    selected = region_name.get()

    num_region = region_map[selected]

    new_data = [[Rooms,Bathroom , YearBuilt, Distance, Landsize, num_region]]

